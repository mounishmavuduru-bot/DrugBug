# DrugBug — environment reference (PRD §20).
#
# This is the SUPERSET of every env var across all three systems. In practice each
# service reads its own subset:
#   - inference/.env       <- everything in the "Inference Service" + "Shared" sections
#   - client/.env.local    <- only the NEXT_PUBLIC_* vars (see client/.env.local.example)
#   - module               <- no .env; service identity is granted via a reducer
#
# Every credentialed/GPU-gated capability degrades to an honest "unavailable" state
# (reported in the inference service's /health) when its variable is absent
# (PRD §5.3 / §10.1). No fake pass/fail anywhere.

# =====================================================================
# Shared / external integrations
# =====================================================================

# Anthropic Claude — used ONLY for (a) structured label/packaging vision analysis
# (DrugScan counterfeit layer 4, signal only) and (b) clinician-brief generation.
# Claude NEVER computes interaction risk, identifies the pill, or makes the
# authenticity verdict (PRD §11). Absent -> those layers report "unavailable".
ANTHROPIC_API_KEY=
# Vision/brief model (PRD §12 specifies Claude Sonnet 4; latest Sonnet used).
ANTHROPIC_MODEL=claude-sonnet-4-6

# openFDA — NDC Directory (NDC validity) + Drug Enforcement (recalls). Key is
# OPTIONAL; it only raises the rate limit. (PRD §12)
OPENFDA_API_KEY=

# =====================================================================
# SpacetimeDB module — service-identity writeback (PRD §6/§8/§15)
# =====================================================================

# HTTPS base for the SAME host the client connects to over wss://.
# Local: http://localhost:3000 ; default cloud: https://maincloud.spacetimedb.com
SPACETIME_HTTP=https://maincloud.spacetimedb.com
# Database name the module was published under.
SPACETIME_DB=drugbug
# Bearer token for the allowlisted service identity. Obtain after publishing the
# module and granting via the grant_service_identity reducer (see module/README.md).
SPACETIME_SERVICE_TOKEN=

# =====================================================================
# Inference Service datastores
# =====================================================================

# Postgres 16 — static medical knowledge base (DDInter, TWOSIDES, RxNorm class,
# pill reference, CPIC). PRD §13. The infra/docker-compose.yml provisions this.
POSTGRES_URL=postgresql://drugbug:drugbug@localhost:5432/drugbug_kb

# Redis — scan/inference job queue + cache. Optional: in-process fallback if absent.
REDIS_URL=redis://localhost:6379/0

# =====================================================================
# Object storage (scan images, generated briefs) — Cloudflare R2 or AWS S3
# Signed, expiring URLs; no public buckets (PRD §15). Absent -> local-dir fallback.
# =====================================================================
OBJECT_STORAGE_ENDPOINT=        # R2: https://<account>.r2.cloudflarestorage.com ; S3: leave blank for AWS default
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=      # R2/S3 access key id
OBJECT_STORAGE_SECRET_KEY=      # R2/S3 secret access key
LOCAL_ARTIFACT_DIR=/tmp/drugbug-artifacts   # fallback when object storage is unset

# =====================================================================
# Push notifications — Web Push (VAPID). PRD §14.
# Generate a VAPID keypair once (e.g. `npx web-push generate-vapid-keys`).
# The PUBLIC key is also exposed to the client as NEXT_PUBLIC_VAPID_PUBLIC_KEY.
# Native APNs/FCM creds (Capacitor) are configured in the native build, not here.
# =====================================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# =====================================================================
# DSCSA VRS — serialized manufacturer verification (DrugScan counterfeit layer 5).
# CREDENTIAL-GATED (PRD §10.1/§21): requires Authorized-Trading-Partner status +
# a VRS provider relationship (TraceLink/Spherity/Antares/Movilitas). Absent ->
# "serialized verification unavailable — ATP credentials not configured".
# =====================================================================
DSCSA_VRS_ENDPOINT=
DSCSA_VRS_CLIENT_ID=
DSCSA_VRS_CLIENT_SECRET=
DSCSA_VRS_ATP_GLN=              # your ATP's GS1 Global Location Number

# =====================================================================
# Inference Service — model weights (GPU-trained; PRD §11/§21).
# Absent -> the capability reports "unavailable"; serving falls back to the
# always-on deterministic paths (KB pairs, mechanistic overlay, per-layer breakdown).
# =====================================================================
CASCADE_GNN_WEIGHTS=
PILL_DETECTOR_WEIGHTS=
PILL_EMBEDDER_WEIGHTS=
IMPRINT_OCR_WEIGHTS=
ADHERENCE_POPULATION_MODEL=
ADHERENCE_MODEL_DIR=/tmp/drugbug-adherence

# Dataset/model version stamps recorded with each result for auditability (PRD §18).
MODEL_VERSION=cascade-gnn-0.0.0+kb-overlay
KB_VERSION=ddinter-2.0

# =====================================================================
# PharmacoFit (PGx) — PharmCAT (Java subprocess). PRD §10.4.
# Absent -> /pgx returns "PharmCAT not installed".
# =====================================================================
PHARMCAT_JAR=
JAVA_BIN=java

# =====================================================================
# Inference Service — misc
# =====================================================================
# Comma-separated client origins allowed by CORS (the Next.js client).
CORS_ORIGINS=http://localhost:3000,https://localhost:3000
# Public, no-key API bases (rarely changed).
RXNAV_BASE=https://rxnav.nlm.nih.gov
OPENFDA_BASE=https://api.fda.gov
DAILYMED_BASE=https://dailymed.nlm.nih.gov

# =====================================================================
# Client (Next.js) — PUBLIC, browser-exposed. Full subset in client/.env.local.example.
# Anything prefixed NEXT_PUBLIC_ is shipped to the browser; never put secrets here.
# =====================================================================
# SpacetimeDB realtime endpoint (wss in prod, ws://localhost:3000 for a local instance).
NEXT_PUBLIC_STDB_URI=wss://maincloud.spacetimedb.com
NEXT_PUBLIC_STDB_DB=drugbug
# Base URL of the Python inference service the client calls over HTTPS.
NEXT_PUBLIC_INFERENCE_URL=http://localhost:8000
# VAPID PUBLIC key (must match VAPID_PUBLIC_KEY above) for web-push subscription.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
