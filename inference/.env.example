# DrugBug Inference Service — environment (PRD §20).
# Copy to .env and fill in. Every credentialed capability degrades to an honest
# "unavailable" state in /health when its variable is absent (PRD §5.3/§10.1).

# ---- Service ----
MODEL_VERSION=cascade-gnn-0.0.0+kb-overlay
KB_VERSION=ddinter-2.0
# Comma-separated client origins for CORS (the Next.js client).
CORS_ORIGINS=http://localhost:3000,https://localhost:3000

# ---- SpacetimeDB writeback (service identity) ----
# HTTP base for the same host the client connects to over wss://
SPACETIME_HTTP=https://maincloud.spacetimedb.com
SPACETIME_DB=drugbug
# Bearer token for the allowlisted service identity (see README bootstrap).
SPACETIME_SERVICE_TOKEN=

# ---- Postgres knowledge base (DDInter, TWOSIDES, RxNorm class, pill ref, CPIC) ----
POSTGRES_URL=postgresql://drugbug:drugbug@localhost:5432/drugbug_kb

# ---- Redis (scan job queue; optional — in-process fallback when absent) ----
REDIS_URL=redis://localhost:6379/0

# ---- External integrations ----
# openFDA: key optional (raises rate limit).
OPENFDA_API_KEY=
# Anthropic: required for Claude vision (scan layer 4) + brief generation.
ANTHROPIC_API_KEY=
# Vision/brief model (PRD §12 specifies Claude Sonnet 4; latest Sonnet used).
ANTHROPIC_MODEL=claude-sonnet-4-6
# Public, no key:
RXNAV_BASE=https://rxnav.nlm.nih.gov
OPENFDA_BASE=https://api.fda.gov
DAILYMED_BASE=https://dailymed.nlm.nih.gov

# ---- DSCSA VRS (counterfeit layer 5 — credential-gated, PRD §10.1/§21) ----
# Requires ATP status + a VRS provider relationship. Absent -> "serialized
# verification unavailable — ATP credentials not configured".
DSCSA_VRS_ENDPOINT=
DSCSA_VRS_CLIENT_ID=
DSCSA_VRS_CLIENT_SECRET=
DSCSA_VRS_ATP_GLN=

# ---- Object storage (scan images, briefs). Absent -> local dir fallback. ----
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
LOCAL_ARTIFACT_DIR=/tmp/drugbug-artifacts

# ---- Model weights (absent -> capability reports "unavailable") ----
CASCADE_GNN_WEIGHTS=
PILL_DETECTOR_WEIGHTS=
PILL_EMBEDDER_WEIGHTS=
IMPRINT_OCR_WEIGHTS=
ADHERENCE_POPULATION_MODEL=
ADHERENCE_MODEL_DIR=/tmp/drugbug-adherence

# ---- PharmCAT (Java subprocess) ----
# Path to pharmcat.jar; absent -> /pgx returns "PharmCAT not installed".
PHARMCAT_JAR=
JAVA_BIN=java
